    <!-- NAVBAR -->
    <header class="navbar">
      <div class="logo">LOGO</div>

      <nav>
        <a href="dashboardLoggedIn">Home</a>
        <a href="signUpEvents">Volunteer Now!</a>
        <a href="createEvent">Need Volunteers?</a>
      </nav>

      <!-- Profile dropdown -->
      <div class="profile-wrapper">
        <button class="profile-trigger">
          <div class="avatar" id="avatar-initial"></div>
          <span class="profile-email" id="display-email"></span>
          <svg class="chevron" viewBox="0 0 16 16" fill="none">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="dropdown">
          <div class="dropdown-header">
            <div class="dh-email" id="header-email"></div>
          </div>

          <div class="section-label">User Information</div>

          <a class="dropdown-item" href="userProfile">
            <div class="item-icon icon-github"></div>
            <div>
              <div class="item-title">User Profile</div>
            </div>
          </a>

          <a class="dropdown-item" href="viewGroup">
            <div class="item-icon icon-slack"></div>
            <div>
              <div class="item-title">User Groups</div>
            </div>
          </a>

          <a class="dropdown-item" href="viewOrganization">
            <div class="item-icon icon-jira"></div>
            <div>
              <div class="item-title">User Organization</div>
            </div>
          </a>

          <div class="dropdown-divider"></div>

          <a class="dropdown-item sign-out" id="logoutBtn">
            <div class="item-title">Logout</div>
          </a>
        </div>
      </div>
    </header>


    <!-- MAIN CONTENT -->
    <main class="container">

      <!-- TABS -->
      <div class="tab-vertical-container">
        <div class="tab-vertical-buttons">
          <button class="tablinks" data-tab="Profile">Organization Profile</button>
          <button class="tablinks" data-tab="Applications">View Applications</button>
          <button class="tablinks" data-tab="Events">View Current Events</button>
          <button class="tablinks" data-tab="CreateEvent">Create New Event</button>
        </div>

        <div class="tab-vertical-content">
          <div id="Profile" class="tabcontent">
            <h1 id="org-name">Organization Name</h1>
            <section class="card large-card">
              <div class="org-layout">
                <div id="org-image" class="org-image"></div>
                <div id="org-description" class="org-text">
                  <p>This is the organization's bio, contact info, and links.</p>
                </div>
              </div>
              <button id="editOrgBtn">Edit Organization</button>

              <form id="editOrgForm" style="display:none;">
                <label>Organization Name: <input type="text" id="editOrgName" required></label><br>
                <label>Description:<br>
                  <textarea id="editOrgIntro" rows="4" cols="40"></textarea>
                </label><br>
                <button type="submit" id="saveEditOrgBtn">Save</button>
                <button type="button" id="cancelEditOrgBtn">Cancel</button>
              </form>
            </section>

            <!-- Shown only when user has NO org -->
            <div id="noOrgSection" style="display: none;">
              <div class="center">
                <h2 class="section-title" style="padding: 20px">
                  You don't have an organization yet — Create one here:
                </h2>
                <div class="card">
                  <form id="createOrgForm">
                    <input type="text" id="orgNameInput" placeholder="Organization name" required
                          style="width: 100%; padding: 8px; margin-bottom: 10px;">
                    <textarea id="orgIntroInput" rows="4" placeholder="Organization description"
                              style="width: 100%; padding: 8px;"></textarea>
                    <button type="submit" style="margin-top: 10px; padding: 10px 20px;">Create Org</button>
                  </form>
                </div>
              </div>
            </div>

          </div>

          <div id="Applications" class="tabcontent">
            <h3 id="applications-title">User Applications</h3>
            <div id="applications-container" class="event-grid">
              <div class="event-card placeholder"><p>No applications yet.</p></div>
            </div>
          </div>

          <div id="Events" class="tabcontent">
            <h3 id="upcomingEventsTitle">Upcoming Events</h3>
            <div id="events-container" class="event-grid">
              <div class="event-card placeholder"><p>No events yet.</p></div>
            </div>
          </div>

          <div id="CreateEvent" class="tabcontent">
            <h3>Create New Event</h3>
            <form id="create-event-form">
              <label>Service Name: <input type="text" name="service_name" required></label><br>
              <label>Description:<br>
                <textarea name="info_text" rows="4" cols="40"></textarea>
              </label><br>
              <label>Start Date/Time: <input type="datetime-local" name="time_start" required></label><br>
              <label>Number of Volunteers Needed: <input type="number" name="estimated_volunteers" min="1"></label><br>
              <label>How many hours is the event? <input type="number" name="estimated_hours" min="1"></label><br>
              <label>Visible to Public:
                <select name="visibility_public">
                  <option value="true">Yes</option>
                  <option value="false">No</option>
                </select>
              </label><br>
              <label>Applications Open:
                <select name="applications_open">
                  <option value="true">Yes</option>
                  <option value="false">No</option>
                </select>
              </label><br>
              <button type="submit" id="createEventBtn">Create Event</button>
            </form>
          </div>
        
        </div>
      
      </div>

    </main>

    <!-- TODO: Add a working email to contact, and links to any social media pages we create-->
    <footer class="footer">
      <div>Follow Us ● ● ● ●</div>
      <div>Contact Us: email@email.com</div>
    </footer>

    <script type="module" src="/js/functions.js"></script>
    <script type="module">
      import { handleLogout, fetchWithAuth } from "/js/auth.js";
      import { fetchOrg, fetchEvents, initEventActions, initEditOrg, fetchApplications, initApplicationActions } from "/js/functions.js";

      document.addEventListener("DOMContentLoaded", async () => {

        const openTab = sessionStorage.getItem("openTab");
        if (openTab) {
          sessionStorage.removeItem("openTab");
          const tabBtn = document.querySelector(`.tab-vertical-buttons button[data-tab="${openTab}"]`);
          if (tabBtn) tabBtn.click();
        }
        
        // Initial page load
        await fetchOrg(fetchWithAuth);
        await fetchEvents(fetchWithAuth);
        await fetchApplications(fetchWithAuth);
        initApplicationActions(fetchWithAuth);
        initEventActions(fetchWithAuth);
        initEditOrg(fetchWithAuth);

        // Create Org form
        document.getElementById("createOrgForm").addEventListener("submit", async (e) => {
          e.preventDefault();

          const org_name = document.getElementById("orgNameInput").value.trim();
          const intro_text = document.getElementById("orgIntroInput").value.trim();

          if (!org_name) {
            alert("Please enter an organization name.");
            return;
          }

          try {
            const res = await fetchWithAuth("/api/orgs", "POST", { org_name, intro_text });
            if (res.error) { alert("Error creating organization: " + res.error); return; }

            alert("Organization created successfully!");
            document.getElementById("createOrgForm").reset();
            await fetchOrg(fetchWithAuth);
            document.querySelector('.tab-vertical-buttons button[data-tab="Profile"]').click();
          } catch (err) {
            console.error("Create organization failed:", err);
            alert("Failed to create organization. Check console for details.");
          }
        });

        // Create Event form
        document.getElementById("create-event-form").addEventListener("submit", async (e) => {
          e.preventDefault();
          const form = e.target;

          const payload = {
            service_name: form.service_name.value.trim(),
            info_text: form.info_text.value.trim(),
            time_start: form.time_start.value,
            estimated_volunteers: parseInt(form.estimated_volunteers.value),
            estimated_hours: parseInt(form.estimated_hours.value),
            visibility_public: form.visibility_public.value === "true",
            applications_open: form.applications_open.value === "true"
          };

          try {
            const res = await fetchWithAuth("/api/services", "POST", payload);
            if (res.error) { alert("Error creating event: " + res.error); return; }

            alert("Event created successfully!");
            form.reset();
            await fetchEvents(fetchWithAuth);
          } catch (err) {
            console.error("Failed to create event:", err);
            alert("Failed to create event. Check console for details.");
          }
        });

        const user = await fetchWithAuth("/api/userProfileData");
        if (user && user.display_name) {
          const userEmail = user.display_name;
          document.getElementById("display-email").textContent = userEmail;
          document.getElementById("header-email").textContent = userEmail;
          document.getElementById("avatar-initial").textContent = userEmail[0].toUpperCase();
        }

        // Navigation
        // document.getElementById("profileBtn").onclick = () => window.location.href = "/userProfile";
        // document.getElementById("signUpEvents").onclick = () => window.location.href = "/signUpEvents";
        // document.getElementById("createEvent").onclick = () => window.location.href = "/createEvent";
        // document.getElementById("aboutUs").onclick = () => window.location.href = "/aboutUs";
        // document.getElementById("createGroups").onclick = () => window.location.href = "/createGroups";
        // document.getElementById("dashboardLoggedIn").onclick = () => window.location.href = "/dashboardLoggedIn";
        document.getElementById("logoutBtn").onclick = async () => {
          await handleLogout();
          window.location.href = "/dashboard";
        };

      });
    </script>
  </body>
</html>
