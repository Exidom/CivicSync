<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CivicSync Create Groups Page</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <!-- NAVBAR -->
  <header class="navbar">
    <!-- TODO: Insert a logo, either ours or the org's stored logo -->
    <div class="logo">LOGO</div>

    <nav>
      <a id="signUpEvents">Volunteer Now!</a>
      <a id="createEvent">Need Volunteers?</a>
      <a id="aboutUs">About Us</a>
    </nav>

    <button id="logoutBtn" class="logout-btn">Logout</button>
  </header>

  <!-- MAIN CONTENT -->  
  <main class="container">
    <div id="hasGroupSection" style="display:none;">
      <h1>Your Groups:</h1>
      <section class="card-container" id="groupList"></section>
      <div class="center">
        <h2>Want to join or create another group? </h2>
      </div>
    </div>

    <div id="noGroupSection" style="display:none;">
      <h1>Create a group:</h1>

      <section class="card-container">
        <div class="card">
          <form id="createGroupForm">
            <input type="text" id="group_name" placeholder="Group Name" required />
            <textarea id="group_intro_text" rows="4" placeholder="Intro Text"></textarea>
            <button type="submit">Create Group</button>
          </form>
        </div>
      </section>
      
      <h1>Join a group:</h1>
      <section class="card-container">
        <div class="center">
          <div class="card">
            <form id="groupInviteForm">
              <input type="text" id="groupCode" placeholder="Enter invite code">
            </form>
            <button id="groupCodeSubmit">Submit</button>
          </div>
        </div>
      </section>
    </div>

    <h2>Other links for testing: </h2>
    <div class="center">
      <button id="dashboardLoggedIn" class="grey-btn">Dashboard Logged In</button>
      <button id="userProfileBtn" class="grey-btn">User Profile</button>
      <button id="viewGroup" class="grey-btn">View Group</button>
      <button id="viewOrganization" class="grey-btn">View Organization</button>
    </div>
  </main>

  <!-- TODO: Add a working email to contact, and links to any social media pages we create-->
  <footer class="footer">
    <div>Follow Us: ● ● ● ●</div>
    <div>Contact Us: contactus@civicsync.org</div>
  </footer>

  <script type="module" src="/js/functions.js"></script>

  <script type="module">
      import { handleLogout } from "/js/auth.js";
      import { initCreateGroups } from "/js/functions.js";

      document.addEventListener("DOMContentLoaded", () => {
        initCreateGroups();
      });

      // Logout Button
      document.getElementById("logoutBtn").onclick = async () => {
          await handleLogout();
          window.location.href = "/dashboard";
      };

      //Navbar links
      document.getElementById("signUpEvents").onclick = async () => {
          window.location.href = "/signUpEvents";
      };

      document.getElementById("createEvent").onclick = async () => {
          window.location.href = "/createEvent";
      };

      document.getElementById("aboutUs").onclick = async () => {
          window.location.href = "/aboutUs";
      };

      // Testing Buttons
      document.getElementById("dashboardLoggedIn").onclick = async () => {
          window.location.href = "/dashboardLoggedIn";
      };

      document.getElementById("userProfileBtn").onclick = async () => {
          window.location.href = "/userProfile";
      };

      document.getElementById("viewGroup").onclick = async () => {
          window.location.href = "/viewGroup";
      };

      document.getElementById("viewOrganization").onclick = async () => {
          window.location.href = "/viewOrganization";
      };

  </script>
</body>
</html>
