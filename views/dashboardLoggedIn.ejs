<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CivicSync Logged In Home Page</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <!-- NAVBAR -->
  <header class="navbar">
    <div class="logo">LOGO</div>

    <nav>
      <a href="dashboardLoggedIn">Home</a>
      <a href="signUpEvents">Volunteer Now!</a>
      <a href="createEvent">Need Volunteers?</a>
    </nav>

    <!-- Profile dropdown -->
    <div class="profile-wrapper">
      <button class="profile-trigger">
        <div class="avatar" id="avatar-initial"></div>
        <span class="profile-email" id="display-email"></span>
        <svg class="chevron" viewBox="0 0 16 16" fill="none">
          <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="dropdown">
        <div class="dropdown-header">
          <div class="dh-email" id="header-email"></div>
        </div>

        <div class="section-label">User Information</div>

        <a class="dropdown-item" href="userProfile">
          <div>
            <div class="item-title">User Profile</div>
          </div>
        </a>

        <a class="dropdown-item" href="viewGroup">
          <div>
            <div class="item-title">User Groups</div>
          </div>
        </a>

        <a class="dropdown-item" href="viewOrganization">
          <div>
            <div class="item-title">User Organization</div>
          </div>
        </a>

        <div class="dropdown-divider"></div>

        <a class="dropdown-item sign-out" id="logoutBtn">
          <div class="item-title">Logout</div>
        </a>
      </div>
    </div>
  </header>

  <!-- MAIN CONTENT -->
  <main class="container-dashboard">

    <div class="hero-banner">
      <h1>Welcome to CivicSync</h1>
      <p>Get started by finding the right group for you</p>
    </div>

    <div class="dashboard-body">

      <div class="membership-card">
        <div class="membership-left">
          <h2>Manage your membership</h2>
          <p>Update your profile, groups, and organization details</p>
        </div>
        <button id="signUpBtn" class="edit-profile-btn">Edit Profile</button>
      </div>

      <div class="stories-section">
        <div class="section-header">
          <h3>Success Stories</h3>
          <div class="section-line"></div>
        </div>
        <div class="stories-list">
          <section class="story-card">
            <div class="org-image"></div>
            <div class="org-text">
              <strong>Community Garden Revival</strong>
              <p>Lorem Ipsum and other example text on repeat. Lorem Ipsum and other example text on repeat.</p>
            </div>
          </section>
          <section class="story-card">
            <div class="org-image"></div>
            <div class="org-text">
              <strong>Youth Coding Workshop</strong>
              <p>Lorem Ipsum and other example text on repeat. Lorem Ipsum and other example text on repeat.</p>
            </div>
          </section>
          <section class="story-card">
            <div class="org-image"></div>
            <div class="org-text">
              <strong>Riverside Park Cleanup</strong>
              <p>Lorem Ipsum and other example text on repeat. Lorem Ipsum and other example text on repeat.</p>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <!-- TODO: Add a working email to contact, and links to any social media pages we create-->
  <footer class="footer">
    <div>Follow Us: ● ● ● ●</div>
    <div>Contact Us: contactus@civicsync.org</div>
  </footer>

  <script type="module">
    import { handleLogout, fetchWithAuth } from "/js/auth.js";
    const user = await fetchWithAuth("/api/userProfileData");
        if (user && user.display_name) {
          const userEmail = user.display_name;
          document.getElementById("display-email").textContent = userEmail;
          document.getElementById("header-email").textContent = userEmail;
          document.getElementById("avatar-initial").textContent = userEmail[0].toUpperCase();
        }
    // document.getElementById("userName").innerText = user.name;
    // document.getElementById("userPic").src = user.picture;
    // TODO: Need to get user info to appear by profile picture!

    // Logout Button
    document.getElementById("logoutBtn").onclick = async () => {
        await handleLogout();
        window.location.href = "/dashboard";
    };

    // Sign up Button
    document.getElementById("signUpBtn").onclick = async () => {
        window.location.href = "/userProfile";
    };

    // //Navbar links
    // document.getElementById("signUpEvents").onclick = async () => {
    //     window.location.href = "/signUpEvents";
    // };

    // document.getElementById("createEvent").onclick = async () => {
    //     window.location.href = "/createEvent";
    // };

    // document.getElementById("aboutUs").onclick = async () => {
    //     window.location.href = "/aboutUs";
    // };

    // // Testing Buttons
    // document.getElementById("createGroups").onclick = async () => {
    //     window.location.href = "/createGroups";
    // };

    // document.getElementById("viewGroup").onclick = async () => {
    //     window.location.href = "/viewGroup";
    // };

    // document.getElementById("viewOrganization").onclick = async () => {
    //     window.location.href = "/viewOrganization";
    // };

  </script>
</body>
</html>
