<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CivicSync Sign Up For Events</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <header class="navbar">
    <div class="logo">LOGO</div>
    <nav>
      <a id="createEvent">Need Volunteers?</a>
      <a id="aboutUs">About Us</a>
    </nav>
    <button id="logoutBtn" class="logout-btn">Logout</button>
  </header>

  <main class="container">
    <h1>Upcoming Events</h1>
    <div id="eventSignupSection" style="display: none;">
      <section class="event-grid" id="eventSignupList"></section>
    </div>

    <div id="noGroupEventSection" style="display: none;">
      <section class="card-container">
        <div class="center">
          <h2 class="section-title" style="padding: 20px">Join a group to sign up for events:</h2>
          <div class="card" style="border: 1px solid #ccc; padding: 20px;">
            <form id="groupInviteForm">
              <input type="text" id="groupCode" placeholder="Enter your invite code">
            </form>
            <button id="groupCodeSubmit" style="margin-top: 20px;" type="button">Submit</button>
          </div>
        </div>
      </section>
    </div>

    <h2>Other links for testing:</h2>
    <div class="center">
      <button id="dashboardLoggedIn" class="grey-btn">Dashboard Logged In</button>
      <button id="userProfileBtn" class="grey-btn">User Profile</button>
      <button id="createGroups" class="grey-btn">Create Groups</button>
      <button id="viewGroup" class="grey-btn">View Group</button>
      <button id="viewOrganization" class="grey-btn">View Organization</button>
    </div>
  </main>

  <footer class="footer">
    <div>Follow Us: ● ● ● ●</div>
    <div>Contact Us: contactus@civicsync.org</div>
  </footer>

  <script type="module">
    import { handleLogout } from "/js/auth.js";
    import { initSignUpEvents, initJoinGroup } from "/js/functions.js";

    document.addEventListener("DOMContentLoaded", async () => {
      await initSignUpEvents();
      initJoinGroup();
    });

    document.getElementById("logoutBtn").onclick = async () => { await handleLogout(); window.location.href = "/dashboard"; };
    document.getElementById("createEvent").onclick = () => window.location.href = "/createEvent";
    document.getElementById("aboutUs").onclick = () => window.location.href = "/aboutUs";
    document.getElementById("dashboardLoggedIn").onclick = () => window.location.href = "/dashboardLoggedIn";
    document.getElementById("userProfileBtn").onclick = () => window.location.href = "/userProfile";
    document.getElementById("createGroups").onclick = () => window.location.href = "/createGroups";
    document.getElementById("viewGroup").onclick = () => window.location.href = "/viewGroup";
    document.getElementById("viewOrganization").onclick = () => window.location.href = "/viewOrganization";
  </script>
</body>
</html>