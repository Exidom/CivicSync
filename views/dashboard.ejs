<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CivicSync Home Page</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <!-- NAVBAR -->
  <header class="navbar">
    <!-- TODO: Insert a logo, either ours or the org's stored logo -->
    <div class="logo">LOGO</div>

    <nav>
      <a id="dashboard">Home</a>
      <a id="signUpEvents">Volunteer Now!</a>
      <a id="createEvent">Need Volunteers?</a>
    </nav>

    <button id="loginBtn" class="login-btn">Login</button>
  </header>

  <!-- MAIN CONTENT -->
  <main class="container-dashboard">

    <div class="hero-banner">
      <h1>Welcome to CivicSync</h1>
      <p>Interested in volunteering? Get started now!</p>
    </div>

    <div class="dashboard-body">

      <div class="membership-card">
        <div class="membership-left">
          <h2>Ready to make a difference?</h2>
          <p>Create an account to start volunteering with your community</p>
        </div>
        <button id="signUpBtn" class="edit-profile-btn">Let's Get Started!</button>
      </div>

      <div class="stories-section">
        <div class="section-header">
          <h3>Success Stories</h3>
          <div class="section-line"></div>
        </div>
        <div class="stories-list">
          <section class="story-card">
            <div class="org-image"></div>
            <div class="org-text">
              <strong>Community Garden Revival</strong>
              <p>Lorem Ipsum and other example text on repeat. Lorem Ipsum and other example text on repeat.</p>
            </div>
          </section>
          <section class="story-card">
            <div class="org-image"></div>
            <div class="org-text">
              <strong>Youth Coding Workshop</strong>
              <p>Lorem Ipsum and other example text on repeat. Lorem Ipsum and other example text on repeat.</p>
            </div>
          </section>
          <section class="story-card">
            <div class="org-image"></div>
            <div class="org-text">
              <strong>Riverside Park Cleanup</strong>
              <p>Lorem Ipsum and other example text on repeat. Lorem Ipsum and other example text on repeat.</p>
            </div>
          </section>
        </div>
      </div>

    </div>

  </main>

  <!-- TODO: Add a working email to contact, and links to any social media pages we create-->
  <footer class="footer">
    <div>Follow Us: ● ● ● ●</div>
    <div>Contact Us: contactus@civicsync.org</div>
  </footer>

  <script type="module">
    
    // Login Button
    document.getElementById("loginBtn").onclick = async () => {
        window.location.href = "/login";
    };

    // Sign up Button
    document.getElementById("signUpBtn").onclick = async () => {
        window.location.href = "/login";
    };

    //Navbar links
    document.getElementById("signUpEvents").onclick = async () => {
        window.location.href = "/login";
    };

    document.getElementById("createEvent").onclick = async () => {
        window.location.href = "/login";
    };

    document.getElementById("dashboard").onclick = async () => {
      window.location.href = "/dashboard";
    }

  </script>
</body>
</html>
