<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CivicSync User Profile</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <!-- NAVBAR -->
  <header class="navbar">
    <!-- TODO: Insert a logo, either ours or the org's stored logo -->
    <div class="logo">LOGO</div>

    <nav>
      <a id="signUpEvents">Volunteer Now!</a>
      <a id="createEvent">Need Volunteers?</a>
      <a id="aboutUs">About Us</a>
    </nav>

    <button id="logoutBtn" class="logout-btn">Logout</button>
  </header>

  <!-- MAIN CONTENT -->
  <main class="container">

    <h1>User Profile</h1>

    <!-- TODO: Implement the pictures feature <img id="profile-pic" src="default-profile.png" alt="Profile Picture"> -->
    
    <form id="profileForm" class="center">
      
      <label for="email">Email: </label>
      <input type="email" id="email" readonly>

      <label for="firstName">First Name: </label>
      <input type="text" id="firstName" placeholder="Enter your first name">

      <label for="lastName">Last Name: </label>
      <input type="text" id="lastName" placeholder="Enter your last name">

      <label for="phone">Phone Number (must be 10 digits): </label>
      <input type="tel" id="phone" placeholder="Enter your phone number">

      <button id="profileSubmit" type="submit">Save Profile</button>
    </form>

    <section class="card-container">

      <div id="groupSection" style="display: none;">
        <div class="center">
          <h2 class="section-title" style="padding: 20px">Your Groups:</h2>
          <div id="groupList"></div>
          <button id="viewGroup" class="grey-btn" style="margin: 40px;">View Groups</button>
          <h2 class="section-title" style="padding: 20px">Join more! </h2>
          <div class="card">
            <form id="groupInviteForm">
              <input type="text" id="groupCode" style="margin-top: 20px;" placeholder="Enter your invite code">
            </form>
            <button id="groupCodeSubmit" style="margin-top: 20px;" type="submit">Submit</button>
          </div>
          <h2 class="section-title" style="padding: 20px">Or, create your own! </h2>
          <button id="createGroups" class="grey-btn">Create Groups</button>
        </div>
        

        <div id="orgSection" style="display: none;">
          <div class="center">
            <h2 class="section-title" style="padding: 20px">Your Organization:</h2>
            <div class="card" style="border: 10px solid #ccc">
              <h3 id="orgName"></h3>
              <button id="viewOrganization" class="grey-btn" style="margin-top: 80px">View Organization</button>
            </div>
          </div>
        </div>

        <div id="noOrgSection" style="display: none;">
          <div class="center">
            <h2 class="section-title" style="padding: 20px">You don't have an organization, create one here:</h2>
            <div class="card" style="border: 10px solid #ccc">
              <form id="createOrgForm">
                <input type="text" id="orgNameInput" placeholder="Organization name" required>
                <textarea id="orgIntroInput" rows="4" placeholder="Organization description"></textarea>
                <button type="submit">Create Org</button>
              </form>
            </div>
          </div>
        </div>

      </div>
    </section>


    <div id="eventSection" style="display: none;">
      <div class="center">
        <h2 class="section-title">Your events:</h2>
      </div>

      <section class="card-container" style="flex:none;">
        <div id="eventList"></div>
      </section>
    </div>

    <div id="noEventSection" style="display: none;">
      <div class="center" style="margin-bottom: 20px;">
        <h2 class="section-title" style="padding: 20px">You have no current events, sign up here!</h2>
        <button id="signUpEvents" class="grey-btn">Sign up</button>
      </div>
    </div>


    <div id="noGroupSection" style="display: none;">
      <div class="center">
        <h2 class="section-title" style="padding: 20px">Join a group to gain access to events and orgs! </h2>
        <div class="card">
          <form id="groupInviteForm">
            <input type="text" id="groupCode" style="margin-top: 20px;" placeholder="Enter your invite code">
          </form>
          <button id="groupCodeSubmit" style="margin-top: 20px;" type="submit">Submit</button>
        </div>
        <h2 class="section-title" style="padding: 20px">Or, create your own! </h2>
        <button id="createGroups" class="grey-btn">Create Groups</button>
      </div>
    </div>


    <h2>Other links for testing: </h2>
    <div class="center">
      <button id="dashboardLoggedIn" class="grey-btn">Dashboard Logged In</button>
      <button id="createGroups" class="grey-btn">Create Groups</button>
      <button id="viewGroup" class="grey-btn">View Group</button>
      <button id="viewOrganization" class="grey-btn">View Organization</button>
    </div>
  </main>

  <!-- TODO: Add a working email to contact, and links to any social media pages we create-->
  <footer class="footer">
    <div>Follow Us: ● ● ● ●</div>
    <div>Contact Us: contactus@civicsync.org</div>
  </footer>

  <script type="module">
    import { handleLogout } from "/js/auth.js"; // your Google auth helper
    import { initUserProfile, initCreateOrg, initJoinGroup } from "/js/functions.js";

    document.addEventListener("DOMContentLoaded", () => {
      initUserProfile();
      initCreateOrg();
      initJoinGroup();
    });

    //   if (user.photoURL) {
    //     profilePic.src = user.photoURL;
    //   }

    // // Preview selected profile picture
    // photoInput.addEventListener('change', (e) => {
    //   const file = e.target.files[0];
    //   if (file) {
    //     profilePic.src = URL.createObjectURL(file);
    //   }
    // });

    //   const profileData = {
    //     photoFile: photoInput.files[0] || null
    //   };

    //   console.log('Profile data to save:', profileData);

    // document.getElementById("userName").innerText = user.name;
    // document.getElementById("userPic").src = user.picture;
    // TODO: Need to get user info to appear by profile picture!

    // Logout Button
    document.getElementById("logoutBtn").onclick = async () => {
        await handleLogout();
        window.location.href = "/dashboard";
    };

    //Navbar links
    document.getElementById("signUpEvents").onclick = async () => {
        window.location.href = "/signUpEvents";
    };

    document.getElementById("createEvent").onclick = async () => {
        window.location.href = "/createEvent";
    };

    document.getElementById("aboutUs").onclick = async () => {
        window.location.href = "/aboutUs";
    };

    // Testing Buttons
    document.getElementById("dashboardLoggedIn").onclick = async () => {
        window.location.href = "/dashboardLoggedIn";
    };

    document.getElementById("createGroups").onclick = async () => {
        window.location.href = "/createGroups";
    };

    document.getElementById("viewGroup").onclick = async () => {
        window.location.href = "/viewGroup";
    };

    document.getElementById("viewOrganization").onclick = async () => {
        window.location.href = "/viewOrganization";
    };

  </script>
</body>
</html>
