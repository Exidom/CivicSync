<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CivicSync User Profile</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <!-- NAVBAR -->
  <header class="navbar">
    <div class="logo">LOGO</div>

    <nav>
      <a href="dashboardLoggedIn">Home</a>
      <a href="signUpEvents">Volunteer Now!</a>
      <a href="createEvent">Need Volunteers?</a>
    </nav>

    <!-- Profile dropdown -->
    <div class="profile-wrapper">
      <button class="profile-trigger">
        <div class="avatar" id="avatar-initial"></div>
        <span class="profile-email" id="display-email"></span>
        <svg class="chevron" viewBox="0 0 16 16" fill="none">
          <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="dropdown">
        <div class="dropdown-header">
          <div class="dh-email" id="header-email"></div>
        </div>

        <div class="section-label">User Information</div>

        <a class="dropdown-item" href="userProfile">
          <div>
            <div class="item-title">User Profile</div>
          </div>
        </a>

        <a class="dropdown-item" href="viewGroup">
          <div>
            <div class="item-title">User Groups</div>
          </div>
        </a>

        <a class="dropdown-item" href="viewOrganization">
          <div>
            <div class="item-title">User Organization</div>
          </div>
        </a>

        <div class="dropdown-divider"></div>

        <a class="dropdown-item sign-out" id="logoutBtn">
          <div class="item-title">Logout</div>
        </a>
      </div>
    </div>
  </header>

  <!-- MAIN CONTENT -->
  <main class="container">
    <div class="tab-vertical-container">
    
      <!-- TABS -->
      <div class="tab-vertical-buttons">
        <button class="tablinks" data-tab="Profile">Edit Profile</button>
        <button class="tablinks" data-tab="Groups">Hours & Groups</button>
        <button class="tablinks" data-tab="Organization">Organization</button>
        <button class="tablinks" data-tab="Events">Events</button>
        <button class="tablinks" data-tab="Medals">Medals</button>
        <button class="tablinks" data-tab="Leaderboard">Leaderboard</button>
      </div>

      <div class="tab-vertical-content">

        <div id="Profile" class="tabcontent">
          <h1>User Profile</h1>

          <form id="profileForm" class="center">
            <label>Email:</label>
            <input type="email" id="email" readonly>

            <label>First Name:</label>
            <input type="text" id="firstName">

            <label>Last Name:</label>
            <input type="text" id="lastName">

            <label>Phone Number (must be 10 digits):</label>
            <input type="tel" id="phone">

            <label>Tell people a little bit about yourself:</label>
            <textarea id="userDescription" rows="3" placeholder="User description"></textarea>

            <button type="submit" class="view-event-btn">Save Profile</button>
          </form>
        </div>

        <div id="Groups" class="tabcontent">
          <div id="groupSection">
            <h1>Your Hours:</h1>
            <h3 id="totalHours" style="padding-bottom: 30px;"></h3>

            <h1>Your Groups:</h1>
            <div id="groupList" style="margin-bottom: 30px;"></div>

            <button id="viewGroup" class="view-event-btn" style="margin-bottom: 30px;">View Groups</button>

            <h1>Join more!</h1>
            <div class="card" style ="border-radius: 8px; border: 1px solid #086375;">
              <form id="groupInviteForm">
                <input type="text" id="groupCode" placeholder="Enter invite code">
                <button id="groupCodeSubmit" class="view-event-btn">Join Group</button>
              </form>
            </div>
            <h1 style="margin-top: 50px;">Or, create your own!</h1>
            <button id="createGroups" class="view-event-btn">Create Groups</button>
          </div>

          <div id="noGroupSection">
            <div class="card" style="margin-top: 70px;">
              <form id="groupInviteForm">
                <p>Join a group to gain access to events!</p>
                <input type="text" id="groupCode" placeholder="Enter invite code">
                <button id="groupCodeSubmit" class="view-event-btn">Join Group</button>
              </form>
            </div>
            <h1>Or, create your own!</h1>
            <button id="createGroups" class="view-event-btn">Create Groups</button>
          </div>
        </div>

        <div id="Organization" class="tabcontent">
          <div id="orgSection">
            <h1>Your Organization:</h1>
            <div class="card" style="border-radius: 8px; border: 1px solid #086375;">
              <h3 id="orgName" style="margin-bottom: 40px;"></h3>
              <button class="view-event-btn" id="viewOrganization">View Organization</button>
              <!-- TODO: Determine if we want a 'delete org' option -->
            </div>
          </div>

          <div id="noOrgSection">
            <h3>You don't have an organization, create one here:</h2>
            <form id="createOrgForm">
              <input type="text" id="orgNameInput" placeholder="Organization name">
              <textarea id="orgIntroInput" rows="4" placeholder="Organization description"></textarea>
              <button type="submit">Create Org</button>
            </form>
          </div>
        </div>

        <div id="Events" class="tabcontent">
          <div id="eventSection">
            <h1>Your Events:</h1>
            <div id="eventList"></div>
          </div>

          <div id="noEventSection">
            <h1>You have no current events. Sign up here!</h1>
            <button id="signUpEvents" class="view-event-btn">Sign up for events</button>
          </div>
        </div>

        <div id="Medals" class="tabcontent">
          <h2>Your Medals: </h2>
          <div id="medalsList"></div>
        </div>

        <div id="Leaderboard" class="tabcontent">
          <h2>Leaderboard</h2>
          <p>(Coming soon)</p>
        </div>
      </div>
    </div>
  </main>

    <!-- TODO: Implement the pictures <img id="profile-pic" src="default-profile.png" alt="Profile Picture"> -->
    

  <!-- TODO: Add links to any social media pages we create-->
  <footer class="footer">
    <div>Follow Us: ● ● ● ●</div>
    <div>Contact Us: contactus@civicsync.org</div>
  </footer>

  <script type="module">
    import { handleLogout, fetchWithAuth } from "/js/auth.js"; // your Google auth helper
    import { initUserProfile, initCreateOrg, initJoinGroup, loadMedals } from "/js/functions.js";

    document.addEventListener("DOMContentLoaded", async () => {

      const openTab = sessionStorage.getItem("openTab");
      if (openTab) {
        sessionStorage.removeItem("openTab");
        const tabBtn = document.querySelector(`.tab-vertical-buttons button[data-tab="${openTab}"]`);
        if (tabBtn) tabBtn.click();
      }

      await initUserProfile();
      initCreateOrg();
      initJoinGroup();
      await loadMedals();

      // Page navigation
      const routes = {
        viewGroup: "/viewGroup",
        createGroups: "/createGroups",
        viewOrganization: "/viewOrganization",
        signUpEvents: "/signUpEvents"
      };
      Object.entries(routes).forEach(([id, path]) => {
        const el = document.getElementById(id);
        if (el) {
          el.addEventListener("click", () => {
            window.location.href = path;
          });
        }
      });

      // Event navigation
      const eventList = document.getElementById("eventList");

      if (eventList) {
        eventList.addEventListener("click", (e) => {
          if (e.target.classList.contains("view-event-btn")) {
            const sid = e.target.dataset.sid;

            sessionStorage.setItem("selectedSid", sid);
            sessionStorage.setItem("openTab", "Events"); 

            window.location.href = "/eventDetails";
          }
        });
      }

      // Navbar user info
      const user = await fetchWithAuth("/api/userProfileData");

      if (user && user.display_name) {
        const email = user.display_name;

        document.getElementById("display-email").textContent = email;
        document.getElementById("header-email").textContent = email;
        document.getElementById("avatar-initial").textContent = email[0].toUpperCase();
      }

      document.getElementById("logoutBtn").onclick = async () => {
        await handleLogout();
        window.location.href = "/dashboard";
      };

    });

    //   if (user.photoURL) {
    //     profilePic.src = user.photoURL;
    //   }

    // // Preview selected profile picture
    // photoInput.addEventListener('change', (e) => {
    //   const file = e.target.files[0];
    //   if (file) {
    //     profilePic.src = URL.createObjectURL(file);
    //   }
    // });

    //   const profileData = {
    //     photoFile: photoInput.files[0] || null
    //   };

    //   console.log('Profile data to save:', profileData);

    // document.getElementById("userName").innerText = user.name;
    // document.getElementById("userPic").src = user.picture;
    // TODO: Need to get user info to appear by profile picture!

  </script>
</body>
</html>
