<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CivicSync User Profile</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <!-- NAVBAR -->
  <header class="navbar">
    <!-- TODO: Insert a logo, either ours or the org's stored logo -->
    <div class="logo">LOGO</div>

    <nav>
      <a id="signUpEvents">Volunteer Now!</a>
      <a id="createEvent">Need Volunteers?</a>
      <a id="aboutUs">About Us</a>
    </nav>

    <button id="logoutBtn" class="logout-btn">Logout</button>
  </header>

  <!-- MAIN CONTENT -->
  <main class="container">

    <!-- Content goes here -->
    <h1>User Profile</h1>

    <img id="profile-pic" src="default-profile.png" alt="Profile Picture">

    <form id="profileForm" class="center">
      <!-- TODO: Pull the users email & any of the other 3 inputs from the database -->
      <label for="email">Email: </label>
      <input type="email" id="email" readonly>

      <label for="firstName">First Name: </label>
      <input type="text" id="firstName" placeholder="Enter your first name">

      <label for="lastName">Last Name: </label>
      <input type="text" id="lastName" placeholder="Enter your last name">

      <label for="phone">Phone Number: </label>
      <input type="tel" id="phone" placeholder="Enter your phone number">

      <!-- TODO: Send the info entered above to the database -->
      <button id="profileSubmit" type="submit">Save Profile</button>
    </form>

    <section class="card-container">
      <!--user.hasOrg == true-->
      <% if (1) { %>
        <div class="center">
          <h2 class="section-title" style="padding: 20px">Your organization:</h2>
            <div class="card" style="border: 10px solid #ccc">
              <h3>*Organization's name here*</h3>
              <button id="viewOrganization" class="grey-btn" style="margin-top: 80px">View Organization</button>
            </div>
          <!--if user.hasGroup == true-->
          <% if (1) { %>
        </div>
          <div class="center">
            <h2 class="section-title" style="padding: 20px">Your group:</h2>
            <div class="card" style="border: 10px solid #ccc;">
              <h3>*Group members' names here*</h3>
              <button id="viewGroup" class="grey-btn" style="margin-top: 80px;">View Group</button>
            </div>
          </div>
          <!--if user.hasGroup == false-->
          <% } else { %>
          <h2 class="section-title" style="padding: 20px">Join a group! </h2>
          <div class="card" style="border: 10px solid #ccc">
            <form id="groupInviteForm">
              <input type="text" id="groupCode" placeholder="Enter your invite code">
            </form>
            <button id="groupCodeSubmit" style="margin-top: 20px;" type="submit">Submit</button>
          </div>
          <h2 class="section-title" style="padding: 20px">Or, create your own! </h2>
          <button id="createGroups" class="grey-btn">Create Groups</button>
        </div>
          <% } %>
    </section>
          <!--if user.hasEvents == true-->
          <% if (1) { %>

          <div class="center">
            <h2 class="section-title">Planned events:</h2>
          </div>

          <section class="card-container" style="flex:none;">
            <div class="card">
              <h3>Park Cleanup</h3>
              <p>March 28</p>
            </div>

            <div class="card">
              <h3>Food Drive</h3>
              <p>April 2</p>
            </div>
          </section>

          <!--if user.hasEvents == false-->  
          <% } else { %>
            <div class="center" style="margin-bottom: 20px;">
              <h2 class="section-title" style="padding: 20px">You have no current events, sign up here! </h2>
              <button id="signUpEvents" class="grey-btn">Sign up</button>
            </div>
          <% } %>

      <!--if user.hasOrg == false-->
      <% } else { %>
        <div class="center">
          <h2 class="section-title" style="padding: 20px">Join an org! </h2>
            <div class="card" style="border: 10px solid #ccc">
                <form id="orgInviteForm">
                  <input type="text" id="orgCode" placeholder="Enter your invite code">
                </form>
                <button id="orgCodeSubmit" style="margin-top: 20px;" type="submit">Submit</button>
            </div>
        </div>
      <% } %>
    </section>

    <h2>Other links for testing: </h2>
    <div class="center">
      <button id="dashboardLoggedIn" class="grey-btn">Dashboard Logged In</button>
      <button id="createGroups" class="grey-btn">Create Groups</button>
      <button id="viewGroup" class="grey-btn">View Group</button>
      <button id="viewOrganization" class="grey-btn">View Organization</button>
    </div>
  </main>

  <!-- TODO: Add a working email to contact, and links to any social media pages we create-->
  <footer class="footer">
    <div>Follow Us: ● ● ● ●</div>
